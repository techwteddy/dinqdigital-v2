{
  "name": "launchkit",
  "version": "1.0.0",
  "description": "Production-ready SaaS boilerplate — Next.js 15, Supabase, Prisma, Stripe. Ship in days, not months.",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Omar S. M. Abdelfatah",
    "email": "omarsharaf@msn.com",
    "url": "https://www.omarsharaf.me"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OmarSharaf/launchkit.git"
  },
  "homepage": "https://github.com/OmarSharaf/launchkit#readme",
  "bugs": {
    "url": "https://github.com/OmarSharaf/launchkit/issues"
  },
  "keywords": [
    "saas",
    "boilerplate",
    "starter-kit",
    "nextjs",
    "next15",
    "supabase",
    "prisma",
    "stripe",
    "typescript",
    "tailwindcss",
    "multi-tenant",
    "authentication",
    "billing",
    "shadcn"
  ],
  "scripts": {
    "dev": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text-summary --coverageReporters=text",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci:env": "node scripts/copy-ci-env.mjs",
    "ci": "npm run lint && npm run format:check && npm run type-check && npm test && npm run ci:env && npm run build",
    "prepare": "node -e \"if(process.env.HUSKY!=='0'&&process.env.CI!=='true'&&process.env.VERCEL!=='1'){require('child_process').execSync('husky install',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.1",
    "lucide-react": "^0.454.0",
    "next": "^15.0.5",
    "next-themes": "^0.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "resend": "^4.0.1",
    "sharp": "^0.33.5",
    "stripe": "^17.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
