# ============================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ─── APP ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Dinq Digital"
NEXT_PUBLIC_APP_TAGLINE="The smarter way to run, grow, and scale your business."
NEXT_PUBLIC_APP_DESCRIPTION="We build premium websites and intelligent AI systems for modern businesses worldwide."
NEXT_PUBLIC_PRODUCT_CATEGORY="Web Agency · AI Systems"
NEXT_PUBLIC_GITHUB_REPO="https://github.com/dinqdigital/dinqdigital-v2"
NEXT_PUBLIC_DOCS_URL="http://localhost:3000/demo"
NEXT_PUBLIC_SUPPORT_EMAIL=techwithteddy@gmail.com

# ─── DATABASE (Supabase / PostgreSQL) ───────────────────────
# Copy BOTH from Supabase → Project Settings → Database → Connection string (URI).
# Use the same aws-N region prefix for pooler URLs (e.g. aws-1-eu-central-1).
# URL-encode special characters in the password (! → %21, @ → %40, etc.).
#
# App runtime (transaction pooler, port 6543):
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations (direct connection — username is postgres, not postgres.[ref]):
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── SUPABASE AUTH ───────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── STRIPE ─────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook — run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products, then seed with db:seed)
STRIPE_PRICE_STARTER_MONTH=price_...
STRIPE_PRICE_PRO_MONTH=price_...
STRIPE_PRICE_ENTERPRISE_MONTH=price_...

# ─── EMAIL (Resend) ──────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM="Dinq Digital <noreply@dinqdigital.com>"

# ─── OPTIONAL: ANALYTICS ────────────────────────────────────
# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── OPTIONAL: ERROR TRACKING ───────────────────────────────
# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=your-sentry-auth-token
