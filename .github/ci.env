NEXT_PUBLIC_APP_NAME=LaunchKit
NEXT_PUBLIC_APP_TAGLINE=CI build
NEXT_PUBLIC_APP_DESCRIPTION=CI build environment
NEXT_PUBLIC_PRODUCT_CATEGORY=CI
