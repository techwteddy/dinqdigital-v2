NEXT_PUBLIC_DOCS_URL=https://github.com/example/launchkit
NEXT_PUBLIC_SUPPORT_EMAIL=ci@example.com

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ci?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ci?schema=public

NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ci-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=ci-supabase-service-role-key

STRIPE_SECRET_KEY=sk_test_ci_build_only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_ci_build_only
STRIPE_WEBHOOK_SECRET=whsec_ci_build_only

RESEND_API_KEY=re_ci_build_only
